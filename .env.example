# ===========================================================================
# AWA Data Services - Transit External Report
# Copy this file to ".env" and fill in the real values. NEVER commit ".env".
# On a server, prefer systemd EnvironmentFile / Docker env / GitHub Secrets.
# ===========================================================================

# --- CargoWise / WiseGrid (TWD) ---
CW_BASE_URL=https://www-isbint.wisegrid.net
CW_MODULE=TWD
CW_USERNAME=ISB.Your.Username
CW_PASSWORD=__CARGOWISE_PASSWORD__
CW_BRANCH_CODES=DOR,CON
CW_DEPARTMENT_CODE=BRN
REPORT_MONTHS=12

# --- Output ---
OUTPUT_DIR=./output
SHAREPOINT_FILENAME=RCN_External_Customer_Report_MOC.xlsx
UPLOAD=true

# --- Cycle Count report (cycle_count_report.py) ---
CC_BRANCH_CODE=CON
CC_REPORT_MONTHS=12
CC_SHAREPOINT_FOLDER=Cycle Count Report
# CC_DISPLAY_TZ_OFFSET=-6   # fixed offset CargoWise displays timestamps in (shared by cycle count + RTU)

# --- RTU report (rtu_report.py) ---
RTU_BRANCH_CODES=DOR,CON
RTU_GATE_FROM=2024-09-04
RTU_FILENAME=KPIU.xlsx
RTU_SHAREPOINT_FOLDER=RTU Report

# --- K9 Line Item Inventory report - CON (k9_report.py) ---
# Reproduces the "Packages - K9 CON Inspections MOC" saved search and MAINTAINS a
# single growing file (one flat sheet, one row per package per day) as a Power BI
# source. Re-running same-day replaces today's rows (no duplicates).
K9_BRANCH_CODE=CON
K9_FILENAME=K9 Line Item Inventory.xlsx
K9_SHEET_NAME=Inventory
K9_SHAREPOINT_FOLDER=K9
# Package statuses to exclude (not in warehouse / not K9-inspected):
K9_EXCLUDE_STATUS=BKD,ADJ,DEP,UPD,FLO,UPN,PKN,PKD,GIN
# Door/build/staging locations to drop (exact match). Complete this from the live
# saved search if the row count doesn't match the grid.
K9_EXCLUDE_LOCATIONS=BUILD_OLD-1,BUILD_OLD-2,BUILD_OLD-3,BUILD_OLD-4,BUILD_OLD-5,CON_DOOR1,CON_DOOR2,CON_DOOR3,DOOR-1,DOOR-2,DOOR-12

# --- DTU (Dispatch Transportation Units) report - CCC (dtu_report.py) ---
DTU_BRANCH_CODES=CCC
DTU_GATE_FROM=2024-09-04
DTU_FILENAME=DTU.xlsx
DTU_SHAREPOINT_FOLDER=DTU Report

# --- Unknown Received Report (unknown_received_report.py) ---
UNK_BRANCH_CODES=CON
UNK_REPORT_MONTHS=12              # all consignments CLOSED in the last N months
UNK_FILENAME=Unknown Received Report.xlsx
UNK_SHAREPOINT_FOLDER=Uknown Report
# All CON receive consignments closed in last 12 months, full 26-col format
# (Power BI filters to UNKNOWN consignors on its end). ~19,400 rows.

# --- Mike Bonded Check report (mikes_bonded_check_report.py) ---
MBC_BRANCH_CODES=DOR
MBC_SERVICE_LEVEL=STC
MBC_REQUIRE_IN_WAREHOUSE=true     # STC + packages in warehouse; set false for STC only (~332 DOR)
MBC_FILENAME=Mikes bonded check .xlsx
MBC_SHAREPOINT_FOLDER=RTU Report

# --- RCN Pending Services report -> "Services Pending.xlsx" (rcn_pending_services_report.py) ---
RPS_BRANCH_CODES=DOR,CON
RPS_BOOKED_MONTHS=6              # "service booked in the last N months"
RPS_FILENAME=Services Pending.xlsx
RPS_SHAREPOINT_FOLDER=RTU Report
# Saved search "RCN Pending Services (booked but not completed)":
# a service booked in last 6 months + NO service completed.

# --- Services Pending (Freight On Hand) report (services_pending_report.py) ---
SVP_BRANCH_CODES=DOR,CON
SVP_FILENAME=Services Pending - Freight On Hand (Daily).xlsx
SVP_SHAREPOINT_FOLDER=RTU Report
# Saved search: a booked-not-completed AdditionalService + packages in warehouse.

# --- Condor Booking Party Cleanup report (condor_cleanup_report.py) ---
CBP_BRANCH_CODES=CON
CBP_REPORT_MONTHS=1
CBP_BOOKING_WORDS=condor,cargo     # booking party (BKD) must contain ALL these words
CBP_FILENAME=Condor Booking Party Cleanup (Daily).xlsx
CBP_SHAREPOINT_FOLDER=RTU Report

# --- PKG "No Consignment" report (pkg_report.py) ---
PKG_BRANCH_CODES=DOR,CON
PKG_GATE_DAYS=14                  # "receive gate-in in the last N days"
PKG_FILENAME=PKG - No Consignment (Daily).xlsx
PKG_SHAREPOINT_FOLDER=RTU Report
# Saved search "PKG-No Consignment": gate-in in last 14 days + receipt consignment ID blank.
# Consignment/dispatch columns are blank by nature (these packages have no consignment).

# --- Open RTU's report (open_rtu_report.py) ---
OPENRTU_BRANCH_CODES=DOR,CON
OPENRTU_FILENAME=Open RTU's.xlsx
OPENRTU_SHAREPOINT_FOLDER=RTU Report
# Saved search "OPEN RTU'S": created time has date + unload complete has no date.

# --- RCN "No Booking Party" report (rcn_report.py) ---
RCN_BRANCH_CODES=DOR,CON
RCN_REPORT_MONTHS=1               # saved search = "created in the last month"
RCN_FILENAME=RCN - No Booking Party (Daily).xlsx
RCN_SHAREPOINT_FOLDER=RTU Report
# RCN_DISPLAY_TZ_OFFSET=-6        # defaults to CC_DISPLAY_TZ_OFFSET (file standard = UTC-6)
# NOTE: saved-search condition "booking party is blank" is the PARENT shipment's
# booking party (cross-module) and cannot be replicated from the receive-consignment
# feed -> ~3% over-inclusion. Consol ID + Bill To Party are blank for the same reason.

# --- Microsoft Graph / SharePoint (app-only) ---
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=__GRAPH_CLIENT_SECRET__
SHAREPOINT_HOSTNAME=yourtenant.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/DataPrime
SHAREPOINT_ROOT=Clients/ISCM            # all report folders live under this path
SHAREPOINT_ARCHIVE_KEEP=168             # archived copies kept per file before pruning
SHAREPOINT_FOLDER=External Customers Freight Report

# --- Status email (notify.py / run_reports.py) ---
# Needs the Azure app to ALSO have the Graph "Mail.Send" APPLICATION permission
# (admin-consented). NOTIFY_SENDER must be a real mailbox in the tenant.
NOTIFY_SENDER=reports@yourtenant.onmicrosoft.com   # mailbox the email is sent FROM
NOTIFY_TO=louislewies@gmail.com                    # comma-separated recipients
